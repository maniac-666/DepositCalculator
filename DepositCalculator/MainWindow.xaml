<Window x:Class="DepositCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор вклада" Height="520" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F6FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Калькулятор доходности вклада"
                   FontSize="20" FontWeight="Bold" Foreground="#2C3E50"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Сумма вклада -->
        <TextBlock Grid.Row="1" Text="Сумма вклада (руб.):" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="2" x:Name="TbPrincipal" Style="{StaticResource InputStyle}"/>

        <!-- Ставка -->
        <TextBlock Grid.Row="3" Text="Годовая ставка (%):" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="4" x:Name="TbRate" Style="{StaticResource InputStyle}"/>

        <!-- Срок и тип -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Срок (месяцев):" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TbMonths" Width="120" Style="{StaticResource InputStyle}"/>
            </StackPanel>
            <StackPanel Margin="24,0,0,0">
                <TextBlock Text="Тип расчёта:" Style="{StaticResource LabelStyle}"/>
                <RadioButton x:Name="RbSimple" Content="Простые проценты"
                             IsChecked="True" Margin="0,6,0,4" FontSize="12"/>
                <RadioButton x:Name="RbCompound" Content="Сложные проценты"
                             Margin="0,0,0,0" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Кнопка -->
        <Button Grid.Row="6" Content="Рассчитать" Style="{StaticResource BtnStyle}"
                HorizontalAlignment="Stretch" Click="BtnCalculate_Click"/>

        <!-- Результат -->
        <Border Grid.Row="7" Background="#ECF0F1" CornerRadius="6" Padding="16"
                Margin="0,16,0,0" BorderBrush="#BDC3C7" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="TbResultTitle" Text="Результат"
                           FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                <TextBlock x:Name="TbIncome" FontSize="13" Foreground="#27AE60"/>
                <TextBlock x:Name="TbTotal" FontSize="13" Foreground="#2C3E50" Margin="0,4,0,0"/>
                <TextBlock x:Name="TbError" FontSize="13" Foreground="#E74C3C"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
